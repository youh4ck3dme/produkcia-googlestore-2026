# === Aktívne (functions/index.js používa Gemini GenAI) ===
GEMINI_API_KEY=your_gemini_key_here
ICOATLAS_API_KEY=your_icoatlas_key_here
RECAPTCHA_API_KEY=your_recaptcha_api_key_here

# === Voliteľné — Mistral fallback (generateContent po zlyhaní Gemini) ===
# https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_primary_key_here
MISTRAL_API_KEY_BACKUP=your_mistral_backup_key_here
MISTRAL_MODEL=mistral-small-latest